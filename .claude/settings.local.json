{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_TIMEOUT_MS": "600000"
  },
  "permissions": {
    "allow": [
      "Bash(curl -s http://localhost:5173/ -o /tmp_page.html -w \"%{http_code}\\\\n\")",
      "Bash(grep -o 'root' /tmp_page.html)",
      "Bash(gh *)",
      "Bash(git init *)",
      "Bash(git add *)"
    ],
    "deny": []
  }
}
